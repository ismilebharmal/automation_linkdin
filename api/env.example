# Required for /generate (LinkedIn draft). Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Text: use Flash-Lite for highest free-tier headroom; Flash for better quality (see ai.google.dev pricing).
GEMINI_MODEL=gemini-2.5-flash-lite
# Image (Nano Banana): fast / relatively cheap image gen on the same API key.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# auto | gemini | pollinations | openai — auto prefers Gemini image if GEMINI_API_KEY is set, else OpenAI, else Pollinations (no key, demo quality).
IMAGE_BACKEND=auto

# Optional: only if you use IMAGE_BACKEND=openai or want OpenAI for text fallback
OPENAI_API_KEY=

# Optional: https://newsapi.org — more headlines in /trends
NEWS_API_KEY=
# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: raises GitHub search rate limit
GITHUB_TOKEN=
